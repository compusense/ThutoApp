
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Helper: Checks if the path starts with the user's UID
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // --- Games Sandbox ---
    // Path format: games/{developerId}_{timestamp}/{filename}
    match /games/{folderName}/{allPaths=**} {
      // Authenticated users can read game assets (to play them)
      allow read: if request.auth != null;
      
      // Only the developer can manage their own files
      // We check if the folder name starts with the user's UID
      allow write: if request.auth != null && folderName.size() > 28 && folderName.startsWith(request.auth.uid);
    }

    // --- Existing Rules ---
    match /exam-materials/{subRegionId}/{path=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // Sub-Region Admin logic handled in app
    }

    match /timetables/{subRegionId}/{path=**} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
    }

    match /syllabi/{path=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.role == 'super-admin';
    }

    // Profile pictures
    match /profile-pictures/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && userId == request.auth.uid;
    }
  }
}
